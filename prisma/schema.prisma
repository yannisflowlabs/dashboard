// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CallReview {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  bookingUid    String   @unique
  attendeeName  String
  attendeeEmail String
  startTime     DateTime
  status        String   // "showed" | "noshow" | "cancelled"
  calStatus     String   @default("accepted") // "accepted" | "rejected" | "cancelled"
  createdAt     DateTime @default(now())
}

model InstagramSnapshot {
  id          Int      @id @default(autoincrement())
  followers   Int
  postsCount  Int
  createdAt   DateTime @default(now())
}

model InstagramCache {
  id        Int      @id @default(1)
  data      String   // JSON stringifié
  updatedAt DateTime @default(now())
}

model ManychatDmEvent {
  id          Int      @id @default(autoincrement())
  contactId   String?  // ID ManyChat du contact (peut être null si supprimé)
  flowName    String?  // Nom du flow qui a déclenché le DM
  triggeredAt DateTime @default(now())
}

// Acquisition : chaque interaction ManyChat = un événement (commentaire, DM, guide envoyé, email donné…)
// Une même personne peut avoir plusieurs événements (elle réagit à plusieurs vidéos).
model ManychatEvent {
  id          Int      @id @default(autoincrement())
  contactId   String?  // ID ManyChat (jetable : peut disparaître au nettoyage mensuel)
  handle      String?  // @ Instagram
  name        String?  // nom du contact
  email       String?  // email capturé dans le flow (pont vers Cal.com)
  eventType   String   @default("dm")   // comment|dm|subscribed|email_captured|guide_sent|company|individual|custom
  flowName    String?  // nom du flow ManyChat = la vidéo source
  videoLabel  String?  // libellé lisible de la vidéo (dérivé du flow, éditable)
  utmContent  String?  // au cas où un UTM arrive quand même
  raw         String?  // payload brut JSON (debug / champs custom)
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([handle])
  @@index([email])
  @@index([flowName])
}

// Acquisition : lien manuel entre une identité ManyChat (handle) et un email Cal.com,
// quand le pont automatique par email ne s'est pas fait.
model AcquisitionLink {
  id        Int      @id @default(autoincrement())
  handle    String   @unique // @ Instagram côté ManyChat
  email     String   // email côté Cal.com / prospect
  note      String?
  createdAt DateTime @default(now())

  @@index([email])
}

model ManualMetric {
  key       String   @id // ex: "reelsViews"
  value     Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt
}

model Prospect {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String?
  source     String   @default("calcom") // "calcom" | "manual"
  stage      String   @default("prospect") // "prospect" | "call_booked" | "proposal_sent" | "client" | "lost" | "unqualified"
  notes      String?
  calBookingUid String?
  clientSince     DateTime? // date de signature (auto quand stage→client, éditable manuellement)
  stageUpdatedAt  DateTime? // date du dernier changement de stage (auto + éditable)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Suivi clients : un call enregistré (recording + transcript + notes IA)
model ClientCall {
  id             Int      @id @default(autoincrement())
  clientEmail    String   // relie au Prospect par email
  title          String?  // titre du call (ex: "Call découverte")
  callDate       DateTime @default(now())
  recordingUrl   String?  // lien Drive de la vidéo (Google Meet)
  transcriptUrl  String?  // lien Google Doc du transcript
  transcriptText String?  // texte brut du transcript (pour la recherche + génération notes)
  notes          String?  // notes structurées générées par Claude (ou saisies)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientEmail])
}

// Suivi clients : une action à faire (checklist cochable)
model ClientAction {
  id          Int      @id @default(autoincrement())
  clientEmail String   // relie au Prospect par email
  label       String
  done        Boolean  @default(false)
  callId      Int?     // optionnel : action issue d'un call précis
  createdAt   DateTime @default(now())

  @@index([clientEmail])
}

// Suivi clients : infos business (1 par client)
model ClientBusinessInfo {
  clientEmail   String   @id // relie au Prospect par email
  company       String?
  industry      String?
  dealAmount    Int?     // montant du deal en euros
  signedAt      DateTime?
  status        String   @default("active") // "active" | "paused" | "completed"
  sessionsTotal Int?     // nb total de sessions prévues (parcours formation)
  sessionsDone  Int      @default(0) // nb de sessions réalisées
  contextNote   String?  // note libre de contexte perso
  updatedAt     DateTime @updatedAt
}

// Vues Reels par mois (saisie manuelle, une ligne par mois "YYYY-MM")
model ReelsMonthlyView {
  month     String   @id // ex: "2026-06"
  views     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Token OAuth Google (1 seul enregistrement, id=1)
model GoogleToken {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}
