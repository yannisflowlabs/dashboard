// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model CallReview {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  bookingUid    String   @unique
  attendeeName  String
  attendeeEmail String
  startTime     DateTime
  status        String   // "showed" | "noshow" | "cancelled"
  calStatus     String   @default("accepted") // "accepted" | "rejected" | "cancelled"
  createdAt     DateTime @default(now())
}

model InstagramSnapshot {
  id          Int      @id @default(autoincrement())
  followers   Int
  postsCount  Int
  createdAt   DateTime @default(now())
}

model InstagramCache {
  id        Int      @id @default(1)
  data      String   // JSON stringifié
  updatedAt DateTime @default(now())
}

model ManychatDmEvent {
  id          Int      @id @default(autoincrement())
  contactId   String?  // ID ManyChat du contact (peut être null si supprimé)
  flowName    String?  // Nom du flow qui a déclenché le DM
  triggeredAt DateTime @default(now())
}

model ManualMetric {
  key       String   @id // ex: "reelsViews"
  value     Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt
}

model Prospect {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String?
  source     String   @default("calcom") // "calcom" | "manual"
  stage      String   @default("prospect") // "prospect" | "call_booked" | "proposal_sent" | "client" | "lost" | "unqualified"
  notes      String?
  calBookingUid String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Suivi clients : un call enregistré (recording + transcript + notes IA)
model ClientCall {
  id             Int      @id @default(autoincrement())
  clientEmail    String   // relie au Prospect par email
  title          String?  // titre du call (ex: "Call découverte")
  callDate       DateTime @default(now())
  recordingUrl   String?  // lien Drive de la vidéo (Google Meet)
  transcriptUrl  String?  // lien Google Doc du transcript
  transcriptText String?  // texte brut du transcript (pour la recherche + génération notes)
  notes          String?  // notes structurées générées par Claude (ou saisies)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientEmail])
}

// Suivi clients : une action à faire (checklist cochable)
model ClientAction {
  id          Int      @id @default(autoincrement())
  clientEmail String   // relie au Prospect par email
  label       String
  done        Boolean  @default(false)
  callId      Int?     // optionnel : action issue d'un call précis
  createdAt   DateTime @default(now())

  @@index([clientEmail])
}

// Suivi clients : infos business (1 par client)
model ClientBusinessInfo {
  clientEmail   String   @id // relie au Prospect par email
  company       String?
  industry      String?
  dealAmount    Int?     // montant du deal en euros
  signedAt      DateTime?
  status        String   @default("active") // "active" | "paused" | "completed"
  sessionsTotal Int?     // nb total de sessions prévues (parcours formation)
  sessionsDone  Int      @default(0) // nb de sessions réalisées
  contextNote   String?  // note libre de contexte perso
  updatedAt     DateTime @updatedAt
}

// Token OAuth Google (1 seul enregistrement, id=1)
model GoogleToken {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}
